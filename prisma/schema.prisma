// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  username        String   @unique
  passwordHash    String
  name            String?
  role            String   @default("viewer")
  inviteCode      String?
  plan            String   @default("free")
  monthlyQuota    Int      @default(100)
  usedThisMonth   Int      @default(0)
  teamId          Int?
  isAgent         Boolean  @default(false)
  agentInviteCode String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts        Account[]
  videoTasks      VideoTask[]
  copyTasks       CopyTask[]
  publishingTasks PublishingTask[]
  dashboardStats  DashboardStat[]
  projects        Project[]
  createdInvites  InviteCode[]     @relation("InviteCodeCreator")
  usageLogs       UsageLog[]
  teamMembers     TeamMember[]
  createdTeams    Team[]     @relation("TeamOwner")
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  ownerId   Int
  createdAt DateTime @default(now())

  owner     User          @relation("TeamOwner", fields: [ownerId], references: [id])
  members   TeamMember[]
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  teamId    Int
  userId    Int
  role      String   @default("viewer")
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model Account {
  id          Int      @id @default(autoincrement())
  platform    String
  accountId   String
  accountName String
  isBound     Boolean  @default(false)
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  publishingTasks PublishingTask[]
}

model VideoTask {
  id           Int      @id @default(autoincrement())
  userId       Int
  originalFile String
  template     String
  duration     Int
  style        String
  status       String
  outputPath   String?
  progress     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  publishingTasks PublishingTask[]
}

model CopyTask {
  id         Int      @id @default(autoincrement())
  userId     Int
  keywords   String
  platform   String
  style      String
  resultJson String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model PublishingTask {
  id          Int       @id @default(autoincrement())
  userId      Int
  accountId   Int
  videoTaskId Int
  publishTime DateTime?
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  account   Account   @relation(fields: [accountId], references: [id])
  videoTask VideoTask @relation(fields: [videoTaskId], references: [id])
}

model DashboardStat {
  id             Int      @id @default(autoincrement())
  userId         Int
  platform       String
  followers      Int      @default(0)
  publishCount   Int      @default(0)
  engagementRate Float    @default(0)
  date           DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AIAgent {
  id             Int      @id @default(autoincrement())
  name           String
  welcomeMessage String
  replyStyle     String
  promptTemplate String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  trainingDocuments TrainingDocument[]
}

model TrainingDocument {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  type      String
  agentId   Int
  createdAt DateTime @default(now())

  agent AIAgent @relation(fields: [agentId], references: [id])
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  userId      Int
  createdAt   DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  assets Asset[]
}

model Asset {
  id        Int      @id @default(autoincrement())
  fileName  String
  fileType  String
  content   String?
  url       String?
  projectId Int
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model InviteCode {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  createdBy Int
  isUsed    Boolean  @default(false)
  usedBy    Int?     @unique
  createdAt DateTime @default(now())

  creator User @relation("InviteCodeCreator", fields: [createdBy], references: [id])
}

model UsageLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  count     Int      @default(1)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}